{
  admin off
}

(authenticated) {
  forward_auth authelia:9091 {
    uri /api/authz/forward-auth
    copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
  }
}

https://auth.internal.home.arpa {
  tls internal
  reverse_proxy authelia:9091
}

https://grafana.internal.home.arpa {
  tls internal
  import authenticated
  reverse_proxy grafana:3000
}

https://prom.internal.home.arpa, https://prometheus.internal.home.arpa {
  tls internal
  import authenticated
  reverse_proxy prometheus:9090
}

https://loki.internal.home.arpa {
  tls internal
  import authenticated
  reverse_proxy loki:3100
}

https://agents.internal.home.arpa {
  tls internal
  respond "reserved for future agents service" 404
}

https://ai.internal.home.arpa {
  tls internal
  respond "reserved for future ai service" 404
}
